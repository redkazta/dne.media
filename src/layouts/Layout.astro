---
import { ViewTransitions } from "astro:transitions";
import "../styles/global.css";
import { contacts, primaryNav, socialLinks } from "../data/siteContent";

type Props = {
  title: string;
};

const { title } = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <ViewTransitions />
  </head>
  <body class="bg-black text-neutral-200 antialiased selection:bg-white selection:text-black">
    <!-- Noise Texture -->
    <div class="fixed inset-0 z-50 pointer-events-none opacity-[0.03]" style="background-image: url('data:image/svg+xml,%3Csvg viewBox=%220 0 200 200%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22noiseFilter%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.65%22 numOctaves=%223%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23noiseFilter)%22/%3E%3C/svg%3E');"></div>
    
    <!-- Header -->
    <header class="fixed top-0 z-40 w-full mix-blend-difference">
      <div class="mx-auto flex h-20 w-full max-w-[1920px] items-center justify-between px-6 md:px-12">
        <a href="/" class="text-sm font-bold tracking-[0.2em] text-white uppercase hover:opacity-70 transition-opacity">
          DNE Media
        </a>
        <nav>
          <ul class="flex items-center gap-6 md:gap-10">
            {primaryNav.map((item) => (
              <li>
                <a href={item.href} class="text-[10px] md:text-xs font-medium tracking-[0.2em] text-white/70 uppercase transition-colors hover:text-white">
                  {item.label}
                </a>
              </li>
            ))}
          </ul>
        </nav>
      </div>
    </header>

    <!-- Main Content -->
    <main class="mx-auto min-h-screen w-full max-w-[1920px] px-6 pt-24 md:px-12 md:pt-32 pb-20">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="border-t border-white/10 bg-black py-16">
      <div class="mx-auto w-full max-w-[1920px] px-6 md:px-12">
        <div class="grid gap-12 md:grid-cols-4">
          
          <!-- Brand Column -->
          <div class="md:col-span-1">
            <a href="/" class="block mb-6 text-sm font-bold tracking-[0.2em] text-white uppercase">DNE Media</a>
            <p class="text-xs text-neutral-500 leading-relaxed max-w-[200px]">
              Premium production and management services for the modern era.
            </p>
          </div>

          <!-- Links Column -->
          <div class="md:col-span-1">
            <h4 class="mb-6 text-[10px] font-bold tracking-[0.2em] text-white/40 uppercase">Explore</h4>
            <ul class="space-y-3">
              {primaryNav.map((item) => (
                <li>
                  <a href={item.href} class="text-xs text-neutral-400 hover:text-white transition-colors tracking-wide uppercase">
                    {item.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>

          <!-- Contact Column -->
          <div class="md:col-span-1">
            <h4 class="mb-6 text-[10px] font-bold tracking-[0.2em] text-white/40 uppercase">Contact</h4>
            <ul class="space-y-4">
              {contacts.map((contact) => (
                <li>
                  <p class="text-[10px] text-neutral-500 uppercase tracking-wider mb-1">{contact.name}</p>
                  <a href={`mailto:${contact.email}`} class="text-xs text-white hover:text-neutral-400 transition-colors">
                    {contact.email}
                  </a>
                </li>
              ))}
            </ul>
          </div>

          <!-- Social Column -->
          <div class="md:col-span-1">
            <h4 class="mb-6 text-[10px] font-bold tracking-[0.2em] text-white/40 uppercase">Follow</h4>
            <ul class="space-y-3">
              {socialLinks.map((link) => (
                <li>
                  <a href={link.href} target="_blank" rel="noreferrer" class="text-xs text-neutral-400 hover:text-white transition-colors tracking-wide uppercase flex items-center gap-2">
                    {link.label}
                    <span class="text-[8px] opacity-50">↗</span>
                  </a>
                </li>
              ))}
            </ul>
          </div>

        </div>

        <div class="mt-16 flex flex-col md:flex-row justify-between items-center border-t border-white/5 pt-8 text-[10px] text-neutral-600 uppercase tracking-widest">
          <p>&copy; {new Date().getFullYear()} DNE Media. All rights reserved.</p>
          <p class="mt-2 md:mt-0">Mexico City / Global</p>
        </div>
      </div>
    </footer>
  </body>
</html>