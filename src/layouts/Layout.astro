---
import "../styles/global.css";
import { contacts, primaryNav, socialLinks } from "../data/siteContent";

type Props = {
  title: string;
};

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body class="min-h-screen bg-[#0a0a0a] text-white antialiased">
    <header class="border-b border-white/10">
      <div class="mx-auto flex w-full max-w-6xl flex-wrap items-center justify-between gap-3 px-4 py-4 md:px-6">
        <a href="/" class="min-h-11 min-w-11 rounded px-2 py-2 text-xl tracking-[0.22em] text-white no-underline">
          DNE
        </a>
        <nav aria-label="Primary navigation">
          <ul class="flex flex-wrap justify-end gap-1 text-sm">
            {primaryNav.map((item) => (
              <li>
                <a href={item.href} class="inline-flex min-h-11 items-center rounded px-3 text-white/85 no-underline transition hover:text-white">
                  {item.label}
                </a>
              </li>
            ))}
          </ul>
        </nav>
      </div>
    </header>
    <main class="mx-auto w-full max-w-6xl px-4 py-8 md:px-6 md:py-12">
      <slot />
    </main>
    <footer class="border-t border-white/10">
      <div class="mx-auto grid w-full max-w-6xl gap-8 px-4 py-8 md:grid-cols-2 md:px-6">
        <div>
          <p class="font-serif text-2xl">Contact</p>
          <ul class="mt-4 space-y-3">
            {contacts.map((contact) => (
              <li>
                <p class="text-white">{contact.name}</p>
                <a href={`mailto:${contact.email}`} class="inline-flex min-h-11 items-center text-white/80 transition hover:text-white">
                  {contact.email}
                </a>
              </li>
            ))}
          </ul>
        </div>
        <div class="md:justify-self-end">
          <p class="font-serif text-2xl">Social</p>
          <ul class="mt-4 space-y-3">
            {socialLinks.map((link) => (
              <li>
                <a href={link.href} target="_blank" rel="noreferrer noopener" class="inline-flex min-h-11 items-center text-white/80 transition hover:text-white">
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </footer>
  </body>
</html>
