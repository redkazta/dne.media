---
import { ViewTransitions } from "astro:transitions";
import "../styles/global.css";
import { contacts, primaryNav, socialLinks } from "../data/siteContent";

type Props = {
  title: string;
};

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <ViewTransitions />
  </head>
  <body class="min-h-screen bg-[#0a0a0a] text-white antialiased selection:bg-white selection:text-black">
    <div class="fixed inset-0 z-50 pointer-events-none mix-blend-overlay opacity-[0.05]" style="background-image: url('data:image/svg+xml,%3Csvg viewBox=%220 0 200 200%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22noiseFilter%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.65%22 numOctaves=%223%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23noiseFilter)%22/%3E%3C/svg%3E');"></div>
    <header class="fixed top-0 z-50 w-full bg-[#0a0a0a]/90 backdrop-blur-md transition-all duration-500">
      <div class="mx-auto flex w-full max-w-6xl items-center justify-between px-6 py-3 md:px-8">
        <a href="/" class="group relative z-10 flex items-center text-[10px] font-bold tracking-[0.3em] text-white no-underline mix-blend-difference uppercase hover:opacity-70 transition-opacity">
          DNE Media
        </a>
        <nav aria-label="Primary navigation">
          <ul class="flex flex-wrap items-center gap-4 text-[10px] font-medium tracking-[0.2em] uppercase md:gap-6">
            {primaryNav.map((item) => (
              <li>
                <a href={item.href} class="relative text-white/50 no-underline transition-colors duration-300 hover:text-white">
                  {item.label}
                </a>
              </li>
            ))}
          </ul>
        </nav>
      </div>
    </header>
    <main class="mx-auto w-full max-w-6xl px-4 pt-16 pb-8 md:px-6 md:pt-20 md:pb-12">
      <slot />
    </main>
    <footer class="border-t border-white/5 bg-[#0a0a0a] pt-8 pb-6">
      <div class="mx-auto grid w-full max-w-6xl gap-4 px-4 md:grid-cols-2 md:px-6">
        <div class="space-y-6">
          <h3 class="font-serif text-sm md:text-base text-white tracking-wide">Contact</h3>
          <ul class="space-y-4">
            {contacts.map((contact) => (
              <li>
                <p class="text-[10px] uppercase tracking-[0.2em] text-white/30 mb-0.5">
                  {contact.name} {contact.role ? `— ${contact.role}` : ""}
                </p>
                <a href={`mailto:${contact.email}`} class="block text-sm text-white/80 transition-colors hover:text-white font-light tracking-wide">
                  {contact.email}
                </a>
              </li>
            ))}
          </ul>
        </div>
        <div class="md:justify-self-end space-y-6 text-right">
          <h3 class="font-serif text-sm md:text-base text-white tracking-wide">Social</h3>
          <ul class="flex flex-col items-end space-y-2">
            {socialLinks.map((link) => (
              <li>
                <a href={link.href} target="_blank" rel="noreferrer noopener" class="text-[10px] text-white/50 transition-colors hover:text-white uppercase tracking-[0.2em]">
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      </div>
      <div class="mx-auto mt-8 max-w-6xl px-4 text-[10px] uppercase tracking-[0.3em] text-white/10 md:px-6 flex justify-between">
        <span>© {new Date().getFullYear()} DNE Media</span>
        <span>All rights reserved</span>
      </div>
    </footer>
  </body>
</html>
