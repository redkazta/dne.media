---
import { ClientRouter } from "astro:transitions";
import "../styles/global.css";
import { contacts, primaryNav, socialLinks } from "../data/siteContent";

type Props = {
  title: string;
};

const { title } = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <ClientRouter />
  </head>
  <body class="bg-black text-neutral-200 antialiased selection:bg-white selection:text-black">
    <div id="route-loader" class="pointer-events-none fixed left-0 top-0 z-[90] h-[2px] w-0 bg-white/90 opacity-0 transition-[width,opacity] duration-300"></div>
    <div id="page-veil" class="pointer-events-none fixed inset-0 z-[60] bg-black/35 opacity-0 transition-opacity duration-300"></div>
    <!-- Noise Texture -->
    <div class="fixed inset-0 z-50 pointer-events-none opacity-[0.03]" style="background-image: url('data:image/svg+xml,%3Csvg viewBox=%220 0 200 200%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22noiseFilter%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.65%22 numOctaves=%223%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23noiseFilter)%22/%3E%3C/svg%3E');"></div>
    
    <!-- Header -->
    <header class="fixed top-0 z-50 w-full md:mix-blend-difference">
      <div class="mx-auto flex h-14 w-full max-w-[1920px] items-center justify-between border-b border-white/10 bg-black/85 px-4 backdrop-blur md:border-0 md:bg-transparent md:px-8 md:backdrop-blur-none">
        <a href="/" class="relative z-50 text-xs font-bold tracking-[0.2em] text-white uppercase hover:opacity-70 transition-opacity">
          DNE Media
        </a>
        
        <!-- Desktop Nav -->
        <nav class="hidden md:block">
          <ul class="flex items-center gap-8">
            {primaryNav.map((item) => (
              <li>
                <a href={item.href} class="text-[10px] font-medium tracking-[0.2em] text-white/70 uppercase transition-colors hover:text-white">
                  {item.label}
                </a>
              </li>
            ))}
          </ul>
        </nav>

        <!-- Mobile Menu Button -->
        <button id="menu-toggle" class="group relative z-50 flex h-3 w-5 flex-col justify-between md:hidden" aria-label="Toggle Menu">
          <span class="h-[1px] w-full bg-white transition-transform duration-300 origin-right"></span>
          <span class="h-[1px] w-full bg-white transition-opacity duration-300"></span>
          <span class="h-[1px] w-full bg-white transition-transform duration-300 origin-right"></span>
        </button>
      </div>
    </header>

    <!-- Mobile Menu Overlay -->
    <div id="mobile-menu" class="fixed inset-0 z-40 opacity-0 pointer-events-none transition-opacity duration-300 md:hidden">
      <button id="mobile-menu-backdrop" aria-label="Close menu" class="absolute inset-0 bg-black/60"></button>
      <aside id="mobile-drawer" class="absolute inset-y-0 right-0 flex w-[82vw] max-w-xs translate-x-full flex-col border-l border-white/10 bg-neutral-950 px-6 pb-8 pt-20 transition-transform duration-300">
        <nav class="flex flex-col items-start gap-5">
          {primaryNav.map((item, index) => (
            <a 
              href={item.href} 
              class="text-xl font-serif text-white/80 hover:text-white transition-colors tracking-tight opacity-0 translate-y-4 transition-all duration-500"
              style={`transition-delay: ${index * 40}ms`}
            >
              {item.label}
            </a>
          ))}
        </nav>
        <div class="mt-auto border-t border-white/10 pt-6">
          <div class="flex flex-col gap-4">
            {contacts.slice(0, 1).map((c) => (
              <a href={`mailto:${c.email}`} class="text-xs text-neutral-400">{c.email}</a>
            ))}
            <div class="flex flex-wrap gap-4">
              {socialLinks.map((s) => (
                <a href={s.href} target="_blank" rel="noopener noreferrer" class="text-xs uppercase tracking-widest text-white/60">{s.label}</a>
              ))}
            </div>
          </div>
        </div>
      </aside>
    </div>

    <!-- Main Content -->
    <main class="mx-auto min-h-screen w-full max-w-[1920px] px-4 pt-16 md:px-8 md:pt-20 pb-12">
      <slot />
    </main>

    <script>
      function setupMenu() {
        const menuToggle = document.getElementById('menu-toggle');
        const mobileMenu = document.getElementById('mobile-menu');
        const spans = menuToggle?.querySelectorAll('span');
        const navLinks = mobileMenu?.querySelectorAll('nav a');
        const mobileDrawer = document.getElementById('mobile-drawer');
        const mobileBackdrop = document.getElementById('mobile-menu-backdrop');
        let isOpen = false;
        const menuBound = menuToggle?.getAttribute('data-menu-bound') === 'true';
        if (menuBound) return;

        menuToggle?.setAttribute('data-menu-bound', 'true');

        function toggleMenu() {
          isOpen = !isOpen;
          
          if (isOpen) {
            mobileMenu?.classList.remove('opacity-0', 'pointer-events-none');
            mobileDrawer?.classList.remove('translate-x-full');
            document.body.style.overflow = 'hidden';
            
            // Animate Button
            if (spans) {
              spans[0].style.transform = 'rotate(-45deg) translateY(0px)';
              spans[1].style.opacity = '0';
              spans[2].style.transform = 'rotate(45deg) translateY(0px)';
            }

            // Animate Links
            navLinks?.forEach(link => {
               link.classList.remove('opacity-0', 'translate-y-4');
            });

          } else {
            mobileMenu?.classList.add('opacity-0', 'pointer-events-none');
            mobileDrawer?.classList.add('translate-x-full');
            document.body.style.overflow = '';
            
            // Reset Button
            if (spans) {
              spans[0].style.transform = '';
              spans[1].style.opacity = '1';
              spans[2].style.transform = '';
            }

            // Reset Links
            navLinks?.forEach(link => {
               link.classList.add('opacity-0', 'translate-y-4');
            });
          }
        }

        menuToggle?.addEventListener('click', toggleMenu);
        mobileBackdrop?.addEventListener('click', () => {
          if (isOpen) toggleMenu();
        });

        // Close menu when clicking a link
        navLinks?.forEach(link => {
          link.addEventListener('click', () => {
             if (isOpen) toggleMenu();
          });
        });
      }

      // Run on initial load
      function setupSmartMedia() {
        const images = Array.from(document.querySelectorAll('img')) as HTMLImageElement[];
        images.forEach((img) => {
          if (img.getAttribute('data-smart-bound') === 'true') return;
          img.setAttribute('data-smart-bound', 'true');
          img.setAttribute('data-smart-image', '');

          const markLoaded = () => {
            img.classList.add('is-loaded');
          };

          if (img.complete && img.naturalWidth > 0) {
            markLoaded();
          } else {
            img.addEventListener('load', markLoaded, { once: true });
            img.addEventListener('error', markLoaded, { once: true });
          }
        });
      }

      function setupScrollReveal() {
        const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        const blocks = Array.from(document.querySelectorAll('main section, main article, main [data-reveal]')) as HTMLElement[];
        if (prefersReducedMotion) {
          blocks.forEach((block) => {
            block.classList.add('is-visible');
          });
          return;
        }

        const observer = new IntersectionObserver((entries, io) => {
          entries.forEach((entry) => {
            if (!entry.isIntersecting) return;
            (entry.target as HTMLElement).classList.add('is-visible');
            io.unobserve(entry.target);
          });
        }, { threshold: 0.12, rootMargin: '0px 0px -40px 0px' });

        blocks.forEach((block) => {
          if (block.getAttribute('data-reveal-bound') === 'true') return;
          block.setAttribute('data-reveal-bound', 'true');
          if (!block.classList.contains('animate-fade-in')) {
            block.classList.add('reveal-block');
          }
          observer.observe(block);
        });
      }

      function setupRouteLoader() {
        if (document.body.getAttribute('data-route-loader-bound') === 'true') return;
        document.body.setAttribute('data-route-loader-bound', 'true');

        const loader = document.getElementById('route-loader') as HTMLDivElement | null;
        const veil = document.getElementById('page-veil') as HTMLDivElement | null;
        if (!loader || !veil) return;

        let progressTimer: number | null = null;

        const start = () => {
          loader.style.opacity = '1';
          loader.style.width = '24%';
          veil.style.opacity = '1';
          if (progressTimer) window.clearTimeout(progressTimer);
          progressTimer = window.setTimeout(() => {
            loader.style.width = '72%';
          }, 90);
        };

        const finish = () => {
          loader.style.width = '100%';
          window.setTimeout(() => {
            loader.style.opacity = '0';
            loader.style.width = '0%';
            veil.style.opacity = '0';
          }, 220);
        };

        document.addEventListener('click', (event) => {
          const target = event.target as HTMLElement | null;
          const link = target?.closest('a') as HTMLAnchorElement | null;
          if (!link) return;
          const href = link.getAttribute('href');
          if (!href) return;
          if (link.target === '_blank') return;
          if (href.startsWith('#')) return;
          if (href.startsWith('mailto:')) return;
          if (href.startsWith('tel:')) return;
          if (href.startsWith('http') && !href.includes(window.location.host)) return;
          start();
        });

        document.addEventListener('astro:before-preparation', start);
        document.addEventListener('astro:page-load', finish);
      }

      function initGlobalUX() {
        setupMenu();
        setupSmartMedia();
        setupScrollReveal();
        setupRouteLoader();
      }

      initGlobalUX();
      document.addEventListener('astro:page-load', initGlobalUX);
    </script>

    <!-- Footer -->
    <footer class="border-t border-white/10 bg-black py-12">
      <div class="mx-auto w-full max-w-[1920px] px-4 md:px-8">
        <div class="grid gap-8 md:grid-cols-4">
          
          <!-- Brand Column -->
          <div class="md:col-span-1">
            <a href="/" class="block mb-6 text-sm font-bold tracking-[0.2em] text-white uppercase">DNE Media</a>
            <p class="text-xs text-neutral-500 leading-relaxed max-w-[200px]">
              Premium production and management services for the modern era.
            </p>
          </div>

          <!-- Links Column -->
          <div class="md:col-span-1">
            <h4 class="mb-6 text-[10px] font-bold tracking-[0.2em] text-white/40 uppercase">Explore</h4>
            <ul class="space-y-3">
              {primaryNav.map((item) => (
                <li>
                  <a href={item.href} class="text-xs text-neutral-400 hover:text-white transition-colors tracking-wide uppercase">
                    {item.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>

          <!-- Contact Column -->
          <div class="md:col-span-1">
            <h4 class="mb-6 text-[10px] font-bold tracking-[0.2em] text-white/40 uppercase">Contact</h4>
            <ul class="space-y-4">
              {contacts.map((contact) => (
                <li>
                  <p class="text-[10px] text-neutral-500 uppercase tracking-wider mb-1">{contact.name}</p>
                  <a href={`mailto:${contact.email}`} class="text-xs text-white hover:text-neutral-400 transition-colors">
                    {contact.email}
                  </a>
                </li>
              ))}
            </ul>
          </div>

          <!-- Social Column -->
          <div class="md:col-span-1">
            <h4 class="mb-6 text-[10px] font-bold tracking-[0.2em] text-white/40 uppercase">Follow</h4>
            <ul class="space-y-3">
              {socialLinks.map((link) => (
                <li>
                  <a href={link.href} target="_blank" rel="noreferrer" class="text-xs text-neutral-400 hover:text-white transition-colors tracking-wide uppercase flex items-center gap-2">
                    {link.label}
                    <span class="text-[8px] opacity-50">↗</span>
                  </a>
                </li>
              ))}
            </ul>
          </div>

        </div>

        <div class="mt-16 flex flex-col md:flex-row justify-between items-center border-t border-white/5 pt-8 text-[10px] text-neutral-600 uppercase tracking-widest">
          <p>&copy; {new Date().getFullYear()} DNE Media. All rights reserved.</p>
          <p class="mt-2 md:mt-0">Mexico City / Global</p>
        </div>
      </div>
    </footer>
  </body>
</html>
