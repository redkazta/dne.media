---
import Layout from "../layouts/Layout.astro";
import { aboutCopy, managementProfiles, portfolioCategories, services } from "../data/siteContent";
---

<Layout title="DNE Media | Production & Management">
  
  <!-- Hero Section -->
  <section class="min-h-[80vh] flex flex-col justify-center relative">
    <div class="max-w-4xl">
      <span class="block mb-6 text-xs font-bold tracking-[0.3em] uppercase text-neutral-500 animate-fade-in">
        Global Production & Management
      </span>
      <h1 class="font-serif text-5xl md:text-7xl lg:text-8xl leading-[0.9] text-white tracking-tighter mb-8 animate-fade-in delay-100">
        {aboutCopy[0]}
      </h1>
      <p class="max-w-xl text-base md:text-lg text-neutral-400 font-light leading-relaxed animate-fade-in delay-200">
        {aboutCopy[1]}
      </p>
    </div>

    <!-- Scroll Indicator -->
    <div class="absolute bottom-0 right-0 hidden md:flex items-center gap-4 animate-fade-in delay-500">
      <span class="text-[10px] tracking-[0.3em] uppercase text-neutral-600">Scroll</span>
      <div class="h-[1px] w-12 bg-neutral-800"></div>
    </div>
  </section>

  <div class="w-full h-[1px] bg-white/10 my-24"></div>

  <!-- Services Section -->
  <section class="mb-32">
    <div class="grid gap-16 lg:grid-cols-12">
      <div class="lg:col-span-4">
        <h2 class="text-xs font-bold tracking-[0.3em] uppercase text-neutral-500 sticky top-32">
          Services
        </h2>
      </div>
      <div class="lg:col-span-8">
        <div class="grid gap-x-12 gap-y-16 md:grid-cols-2">
          {services.map((service, index) => (
            <div class="group border-t border-white/10 pt-6 transition-colors hover:border-white/40">
              <span class="block mb-4 text-xs font-mono text-neutral-600 group-hover:text-white transition-colors">
                0{index + 1}
              </span>
              <h3 class="text-2xl md:text-3xl font-serif text-neutral-300 group-hover:text-white transition-colors">
                {service}
              </h3>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Portfolio Section -->
  <section class="mb-32">
    <div class="grid gap-16 lg:grid-cols-12">
      <div class="lg:col-span-4">
        <h2 class="text-xs font-bold tracking-[0.3em] uppercase text-neutral-500 sticky top-32">
          Selected Work
        </h2>
      </div>
      <div class="lg:col-span-8">
        <div class="grid gap-8 md:grid-cols-2">
          {portfolioCategories.map((category, i) => (
            <a href={`/${category.slug}`} class={`group block ${i % 2 === 1 ? 'md:mt-16' : ''}`}>
              <div class="relative aspect-[3/4] overflow-hidden bg-neutral-900 mb-4">
                <div class="absolute inset-0 bg-white/5 opacity-0 group-hover:opacity-100 transition-opacity z-10"></div>
                <!-- Placeholder for category image if we had one, using generic gradient for now or just text -->
                <div class="absolute inset-0 flex items-center justify-center bg-neutral-900 border border-white/5 group-hover:border-white/20 transition-colors">
                  <span class="text-xs tracking-[0.2em] uppercase text-neutral-500 group-hover:text-white transition-colors">View Project</span>
                </div>
              </div>
              <h3 class="text-xl font-serif text-white group-hover:text-neutral-300 transition-colors">
                {category.label}
              </h3>
              <p class="text-xs text-neutral-500 uppercase tracking-wider mt-1">Portfolio</p>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Management Section -->
  <section class="mb-32">
    <div class="flex flex-col md:flex-row justify-between items-end mb-16 gap-8">
      <h2 class="text-4xl md:text-6xl font-serif text-white leading-none">
        Management <br /> <span class="text-neutral-600">Roster</span>
      </h2>
      <a href="/artists" class="text-xs font-bold tracking-[0.2em] uppercase text-white border-b border-white/30 pb-1 hover:border-white transition-colors">
        View All Artists
      </a>
    </div>

    <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
      {managementProfiles.slice(0, 3).map((profile) => (
        <a href={`/${profile.slug}`} class="group block">
          <div class="relative aspect-[3/4] overflow-hidden bg-neutral-900 mb-4">
            <img 
              src={profile.image} 
              alt={profile.label} 
              class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-105 grayscale group-hover:grayscale-0"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-black/20 group-hover:bg-transparent transition-colors"></div>
          </div>
          <div class="flex justify-between items-baseline">
            <h3 class="text-lg font-medium text-white group-hover:text-neutral-300 transition-colors">
              {profile.label}
            </h3>
            <span class="text-[10px] tracking-widest uppercase text-neutral-500">Exclusive</span>
          </div>
        </a>
      ))}
    </div>
  </section>

</Layout>