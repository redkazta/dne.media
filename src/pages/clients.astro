---
import Layout from "../layouts/Layout.astro";
import { roster } from "../data/siteContent";
---

<Layout title="Clients | DNE Media">
  <section>
    <p class="text-xs tracking-[0.28em] text-white/60">CLIENTS</p>
    <h1 class="mt-4 text-4xl md:text-6xl">Clients</h1>
    <p class="mt-4 max-w-2xl text-white/75">
      Full extracted list represented from the source evidence.
    </p>
    <ul class="mt-8 grid gap-2 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4">
      {roster.map((client) => (
        <li class="rounded border border-white/10 px-3 py-3 text-sm text-white/85">{client}</li>
      ))}
    </ul>
  </section>
</Layout>
