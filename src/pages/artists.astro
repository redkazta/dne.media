---
import Layout from "../layouts/Layout.astro";
import { managementProfiles, roster } from "../data/siteContent";
---

<Layout title="Artists | DNE Media">
  <section>
    <p class="text-[9px] tracking-[0.3em] text-white/40 uppercase mb-4">Management</p>
    
    <div class="grid grid-cols-2 gap-4 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5">
      {managementProfiles.map((profile) => (
        <a href={`/${profile.slug}`} class="group relative aspect-[3/4] block overflow-hidden bg-neutral-900/50">
          <img 
            src={profile.image} 
            alt={profile.label} 
            class="h-full w-full object-cover transition-all duration-700 group-hover:scale-105 opacity-60 grayscale group-hover:opacity-100 group-hover:grayscale-0"
            loading="lazy"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-transparent to-transparent opacity-0 transition-opacity duration-300 group-hover:opacity-100"></div>
          <div class="absolute bottom-0 left-0 w-full p-3 translate-y-2 transition-transform duration-300 group-hover:translate-y-0 opacity-0 group-hover:opacity-100">
            <h2 class="font-serif text-sm text-white tracking-wide">{profile.label}</h2>
            {profile.tags && (
              <p class="mt-1 text-[8px] uppercase tracking-[0.1em] text-white/50 truncate">
                {profile.tags[0]}
              </p>
            )}
          </div>
        </a>
      ))}
    </div>
    <div class="mt-16 mb-8 border-t border-white/5 pt-8">
      <div class="flex items-baseline justify-between mb-6">
        <h2 class="text-[9px] tracking-[0.3em] text-white/30 uppercase">Roster</h2>
        <span class="text-[9px] text-white/20">{roster.length}</span>
      </div>
      <ul class="flex flex-wrap gap-x-6 gap-y-2 justify-start">
        {roster.map((artist) => (
          <li class="text-[10px] text-white/40 hover:text-white transition-colors cursor-default uppercase tracking-wider">{artist}</li>
        ))}
      </ul>
    </div>
  </section>
</Layout>
