---
import Layout from "../layouts/Layout.astro";
import { managementProfiles, roster } from "../data/siteContent";
---

<Layout title="Artists | DNE Media">
  <section>
    <p class="text-[10px] tracking-[0.28em] text-white/60 uppercase">ARTISTS</p>
    <h1 class="mt-4 font-serif text-2xl md:text-4xl text-white">Artists / Roster</h1>
    <div class="mt-12 grid grid-cols-1 gap-12 sm:grid-cols-2 md:grid-cols-3">
      {managementProfiles.map((profile) => (
        <a href={`/${profile.slug}`} class="group relative aspect-[3/4] block overflow-hidden">
          <img 
            src={profile.image} 
            alt={profile.label} 
            class="h-full w-full object-cover transition-all duration-1000 group-hover:scale-105 opacity-50 grayscale group-hover:opacity-100 group-hover:grayscale-0"
            loading="lazy"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-transparent to-transparent opacity-0 transition-opacity duration-500 group-hover:opacity-100"></div>
          <div class="absolute bottom-0 left-0 w-full p-6 translate-y-4 transition-transform duration-500 group-hover:translate-y-0 opacity-0 group-hover:opacity-100">
            <h2 class="font-serif text-xl text-white tracking-wide">{profile.label}</h2>
            {profile.tags && (
              <p class="mt-2 text-[9px] uppercase tracking-[0.2em] text-white/60">
                {profile.tags.slice(0, 2).join(" / ")}
              </p>
            )}
          </div>
        </a>
      ))}
    </div>
    <div class="mt-24 mb-12 border-t border-white/5 pt-12">
      <div class="flex items-baseline justify-between mb-8">
        <h2 class="text-[10px] tracking-[0.3em] text-white/30 uppercase">Full Roster</h2>
        <span class="text-[9px] text-white/20">{roster.length} Artists</span>
      </div>
      <ul class="flex flex-wrap gap-x-8 gap-y-4 justify-center">
        {roster.map((artist) => (
          <li class="text-[11px] text-white/40 hover:text-white transition-colors cursor-default uppercase tracking-widest">{artist}</li>
        ))}
      </ul>
    </div>
  </section>
</Layout>
