---
import Layout from "../layouts/Layout.astro";
import { managementProfiles, roster } from "../data/siteContent";
---

<Layout title="Artists | DNE Media">
  
  <div class="mb-6 border-b border-white/10 pb-4">
    <h1 class="font-serif text-2xl md:text-4xl text-white mb-1 tracking-tighter">
      Management
    </h1>
    <p class="text-neutral-500 max-w-2xl text-xs font-light leading-relaxed">
      Curated roster of exceptional talent.
    </p>
  </div>

  <!-- Management Grid -->
  <section class="mb-12">
    <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-5 gap-x-3 gap-y-6">
      {managementProfiles.map((profile) => (
        <a href={`/${profile.slug}`} class="group block">
          <div class="relative aspect-[3/4] w-full overflow-hidden bg-neutral-900 mb-3">
            <img 
              src={profile.image} 
              alt={profile.label} 
              class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-105 grayscale group-hover:grayscale-0"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-black/10 group-hover:bg-transparent transition-colors"></div>
          </div>
          
          <div class="flex flex-col gap-0.5">
            <h2 class="font-serif text-base text-white group-hover:text-neutral-300 transition-colors leading-tight">
              {profile.label}
            </h2>
            
            {profile.tags && (
              <p class="text-[10px] uppercase tracking-[0.2em] text-neutral-500 group-hover:text-neutral-400 transition-colors">
                {profile.tags[0]}
              </p>
            )}
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- Roster List -->
  <section class="mb-12 pt-8 border-t border-white/10">
    <div class="grid lg:grid-cols-12 gap-8">
      <div class="lg:col-span-3">
        <h2 class="text-[10px] font-bold tracking-[0.3em] uppercase text-neutral-500">
          Full Roster <span class="text-neutral-700 ml-2">({roster.length})</span>
        </h2>
      </div>
      <div class="lg:col-span-9">
        <ul class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-x-4 gap-y-2">
          {roster.map((artist) => (
            <li class="text-xs text-neutral-400 hover:text-white transition-colors cursor-default tracking-wide">
              {artist}
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

</Layout>