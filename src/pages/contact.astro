---
import Layout from "../layouts/Layout.astro";
import { contacts, socialLinks } from "../data/siteContent";
---

<Layout title="Contact | DNE Media">
  <section class="mb-10 border-b border-white/10 pb-6">
    <div class="grid gap-6 lg:grid-cols-12">
      <div class="lg:col-span-4">
        <p class="mb-2 text-[8px] md:text-[10px] font-bold tracking-[0.3em] uppercase text-neutral-500">Contact</p>
        <h1 class="font-serif text-2xl md:text-4xl text-white tracking-tighter leading-tight">
          Let’s build with purpose.
        </h1>
      </div>
      <div class="lg:col-span-8">
        <p class="max-w-3xl text-sm md:text-base text-neutral-400 font-light leading-relaxed">
          We collaborate with artists, labels and brands through full-scale production, visual storytelling and management. Reach out to the right person below and connect with DNE Media across our channels.
        </p>
      </div>
    </div>
  </section>

  <section class="mb-12">
    <div class="grid gap-3 md:hidden">
      {contacts.map((contact) => (
        <article class="group h-full border border-white/10 bg-neutral-950/60 p-4 transition-colors hover:border-white/30">
          <div class="mb-4 flex items-start justify-between gap-4">
            <div>
              <h2 class="font-serif text-lg text-white leading-tight">{contact.name}</h2>
              {contact.role && <p class="mt-1 text-[10px] uppercase tracking-[0.2em] text-neutral-500">{contact.role}</p>}
            </div>
            <a href={`mailto:${contact.email}`} class="text-[9px] uppercase tracking-[0.2em] text-neutral-500 transition-colors hover:text-white">Email</a>
          </div>
          <p class="mb-5 text-xs text-neutral-400 font-light leading-relaxed">
            {contact.bio}
          </p>
          <a href={`mailto:${contact.email}`} class="mb-4 block font-serif text-base text-white break-words transition-colors hover:text-neutral-300">
            {contact.email}
          </a>
          {contact.socials && (
            <ul class="flex flex-wrap gap-2">
              {contact.socials.map((item) => (
                <li>
                  <a href={item.href} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1 border border-white/15 px-2 py-1 text-[9px] uppercase tracking-[0.18em] text-neutral-400 transition-colors hover:border-white/40 hover:text-white">
                    <span>{item.label}</span>
                    <span>↗</span>
                  </a>
                </li>
              ))}
            </ul>
          )}
        </article>
      ))}
    </div>
    <div class="hidden gap-4 md:grid md:grid-cols-2 xl:grid-cols-3">
      {contacts.map((contact) => (
        <article class="group h-full border border-white/10 bg-neutral-950/60 p-4 md:p-5 transition-colors hover:border-white/30">
          <div class="mb-4 flex items-start justify-between gap-4">
            <div>
              <h2 class="font-serif text-lg md:text-xl text-white leading-tight">{contact.name}</h2>
              {contact.role && <p class="mt-1 text-[10px] uppercase tracking-[0.2em] text-neutral-500">{contact.role}</p>}
            </div>
            <a href={`mailto:${contact.email}`} class="text-[9px] uppercase tracking-[0.2em] text-neutral-500 transition-colors hover:text-white">Email</a>
          </div>
          <p class="mb-5 text-xs md:text-sm text-neutral-400 font-light leading-relaxed">
            {contact.bio}
          </p>
          <a href={`mailto:${contact.email}`} class="mb-4 block font-serif text-base text-white break-words transition-colors hover:text-neutral-300">
            {contact.email}
          </a>
          {contact.socials && (
            <ul class="flex flex-wrap gap-2">
              {contact.socials.map((item) => (
                <li>
                  <a href={item.href} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1 border border-white/15 px-2 py-1 text-[9px] uppercase tracking-[0.18em] text-neutral-400 transition-colors hover:border-white/40 hover:text-white">
                    <span>{item.label}</span>
                    <span>↗</span>
                  </a>
                </li>
              ))}
            </ul>
          )}
        </article>
      ))}
    </div>
  </section>

  <section class="grid gap-8 border-t border-white/10 pt-8 lg:grid-cols-12">
    <div class="lg:col-span-5">
      <h3 class="text-[10px] font-bold tracking-[0.3em] uppercase text-neutral-500 mb-3">DNE Media</h3>
      <p class="font-serif text-xl text-white leading-tight mb-2">Mexico City / Global</p>
      <p class="text-xs text-neutral-400 leading-relaxed">
        Production, content and artist development with an international focus.
      </p>
    </div>
    <div class="lg:col-span-7">
      <h3 class="text-[10px] font-bold tracking-[0.3em] uppercase text-neutral-500 mb-3">Redes</h3>
      <ul class="grid gap-2 sm:grid-cols-2">
        {socialLinks.map((link) => (
          <li>
            <a href={link.href} target="_blank" rel="noopener noreferrer" class="group flex items-center justify-between border border-white/10 px-3 py-2 text-sm text-neutral-300 transition-colors hover:border-white/30 hover:text-white">
              <span>{link.label}</span>
              <span class="text-xs text-neutral-500 transition-colors group-hover:text-white">↗</span>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>

</Layout>
