---
import Layout from "../layouts/Layout.astro";
import { contacts, socialLinks } from "../data/siteContent";
---

<Layout title="Contact | DNE Media">
  <section>
    <p class="text-xs tracking-[0.28em] text-white/60">CONTACT</p>
    <h1 class="mt-4 text-4xl md:text-6xl">Contact Us</h1>
    <div class="mt-8 grid gap-4 sm:grid-cols-2">
      {contacts.map((contact) => (
        <article class="rounded border border-white/10 p-5">
          <p class="text-2xl font-serif">{contact.name}</p>
          <a href={`mailto:${contact.email}`} class="mt-3 inline-flex min-h-11 items-center text-white/85 transition hover:text-white">
            {contact.email}
          </a>
        </article>
      ))}
    </div>
    <div class="mt-8">
      {socialLinks.map((link) => (
        <a href={link.href} target="_blank" rel="noreferrer noopener" class="inline-flex min-h-11 items-center rounded border border-white px-5 text-sm uppercase tracking-[0.14em] text-white no-underline transition hover:bg-white hover:text-black">
          {link.label}
        </a>
      ))}
    </div>
  </section>
</Layout>
