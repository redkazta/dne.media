---
import Layout from "../layouts/Layout.astro";
import { contacts, socialLinks } from "../data/siteContent";
---

<Layout title="Contact | DNE Media">
  <div class="pt-24 pb-12">
    <h1 class="font-serif text-4xl md:text-6xl text-white mb-12">Contact</h1>
    
    <div class="grid gap-16 md:grid-cols-2">
      <div class="space-y-12">
        {contacts.map((contact) => (
          <div>
            <p class="text-[9px] uppercase tracking-[0.3em] text-white/40 mb-2">
              {contact.name}
            </p>
            {contact.role && (
              <p class="text-[9px] uppercase tracking-[0.2em] text-white/20 mb-2">{contact.role}</p>
            )}
            <a href={`mailto:${contact.email}`} class="block font-serif text-2xl md:text-3xl text-white hover:opacity-70 transition-opacity break-all">
              {contact.email}
            </a>
          </div>
        ))}
      </div>

      <div class="md:justify-self-end space-y-4">
        <p class="text-[9px] uppercase tracking-[0.3em] text-white/40 mb-6 text-right">Social</p>
        <div class="flex flex-col items-end gap-2">
          {socialLinks.map((link) => (
            <a href={link.href} target="_blank" rel="noreferrer noopener" class="text-[10px] uppercase tracking-[0.2em] text-white/60 hover:text-white transition-colors">
              {link.label} ↗
            </a>
          ))}
        </div>
      </div>
    </div>
  </div>
</Layout>
