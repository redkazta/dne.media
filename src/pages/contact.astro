---
import Layout from "../layouts/Layout.astro";
import { contacts, socialLinks } from "../data/siteContent";
---

<Layout title="Contact | DNE Media">
  
  <div class="mb-24">
    <h1 class="font-serif text-5xl md:text-7xl text-white mb-8 tracking-tighter">
      Contact
    </h1>
    <p class="text-neutral-500 max-w-2xl text-lg font-light leading-relaxed">
      For inquiries regarding our roster or services, please reach out directly.
    </p>
  </div>

  <div class="grid gap-16 lg:grid-cols-12 lg:gap-24 mb-32">
    
    <!-- Emails Column -->
    <div class="lg:col-span-8">
      <div class="grid gap-16">
        {contacts.map((contact) => (
          <div class="group">
            <p class="text-xs font-bold tracking-[0.3em] uppercase text-neutral-500 mb-4">
              {contact.role || contact.name}
            </p>
            <a href={`mailto:${contact.email}`} class="block font-serif text-3xl md:text-5xl lg:text-6xl text-white hover:text-neutral-400 transition-colors break-words">
              {contact.email}
            </a>
          </div>
        ))}
      </div>
    </div>

    <!-- Info Column -->
    <div class="lg:col-span-4 space-y-16">
      
      <!-- Location -->
      <div>
        <h3 class="text-xs font-bold tracking-[0.3em] uppercase text-neutral-500 mb-6">
          Location
        </h3>
        <p class="text-xl md:text-2xl font-serif text-white">
          Mexico City <br />
          <span class="text-neutral-500">Global</span>
        </p>
      </div>

      <!-- Socials -->
      <div>
        <h3 class="text-xs font-bold tracking-[0.3em] uppercase text-neutral-500 mb-6">
          Social
        </h3>
        <ul class="space-y-4">
          {socialLinks.map((link) => (
            <li>
              <a href={link.url} target="_blank" rel="noopener noreferrer" class="group flex items-center gap-3 text-lg text-neutral-400 hover:text-white transition-colors">
                <span>{link.platform}</span>
                <span class="text-xs opacity-0 -translate-x-2 group-hover:opacity-100 group-hover:translate-x-0 transition-all">↗</span>
              </a>
            </li>
          ))}
        </ul>
      </div>

    </div>

  </div>

</Layout>