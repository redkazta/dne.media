---
import Layout from "../layouts/Layout.astro";
import { categoryMediaBySlug, categoryVideoBySlug, managementProfiles, pages, portfolioCategories } from "../data/siteContent";

export function getStaticPaths() {
  const slugs = new Set([
    ...portfolioCategories.map((item) => item.slug),
    ...managementProfiles.map((item) => item.slug)
  ]);

  return Array.from(slugs).map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params;

const category = portfolioCategories.find((item) => item.slug === slug);
const profile = managementProfiles.find((item) => item.slug === slug);
const page = pages.find((item) => item.slug === slug);

const pageLabel = category?.label ?? profile?.label ?? slug;
const pageTitle = page?.title ?? `${pageLabel} | DNE Media`;
const typeLabel = category ? "Portfolio" : "Artist";
const backLink = category ? "/" : "/artists";
const backText = category ? "Home" : "All Artists";
const categoryMedia = category ? categoryMediaBySlug[category.slug] ?? [] : [];
const categoryVideos = category ? categoryVideoBySlug[category.slug] ?? [] : [];
const embeddedVideos = categoryVideos
  .map((url) => {
    const match = url.match(/vimeo\.com\/(\d+)/);
    if (!match) return null;
    return {
      source: url,
      embed: `https://player.vimeo.com/video/${match[1]}`
    };
  })
  .filter((item): item is { source: string; embed: string } => item !== null);
---

<Layout title={pageTitle}>
  <div class="mb-4 md:mb-8">
    <a href={backLink} class="group inline-flex items-center text-[8px] md:text-[10px] uppercase tracking-[0.2em] text-neutral-500 transition-colors hover:text-white">
      <span class="mr-2 transition-transform group-hover:-translate-x-1">←</span> {backText}
    </a>
  </div>

  {profile || category ? (
    <div class="grid gap-6 md:gap-8 lg:grid-cols-12 lg:gap-16">
      
      <!-- Image Column (Sticky on Desktop) -->
      <div class="lg:col-span-4">
        <div class="sticky top-20">
          <div class="relative aspect-[4/5] md:aspect-[3/4] w-full overflow-hidden bg-neutral-900 mb-4 md:mb-6">
            {(profile?.image || category?.image) ? (
              <img 
                src={profile?.image || category?.image} 
                alt={pageLabel} 
                class="h-full w-full object-cover grayscale"
                loading="lazy" 
              />
            ) : (
              <div class="absolute inset-0 flex items-center justify-center text-neutral-700">
                <span class="text-[10px] tracking-widest uppercase">No Image</span>
              </div>
            )}
          </div>
          
          {profile?.socials && (
            <div class="flex flex-col gap-2 md:gap-3 border-t border-white/10 pt-3 md:pt-4">
              <h3 class="text-[8px] md:text-[10px] font-bold tracking-[0.3em] uppercase text-neutral-600">Connect</h3>
              <div class="flex flex-wrap gap-3 md:gap-4">
                {profile.socials.map(social => (
                  <a href={social.url} target="_blank" rel="noopener noreferrer" class="text-[8px] md:text-[10px] uppercase tracking-widest text-neutral-400 transition-colors hover:text-white flex items-center gap-1">
                    {social.label} <span class="opacity-50">↗</span>
                  </a>
                ))}
              </div>
            </div>
          )}
        </div>
      </div>
      
      <!-- Content Column -->
      <div class="lg:col-span-8 flex flex-col justify-start pt-0 md:pt-2">
        <div class="mb-4 md:mb-8">
          <p class="mb-1 md:mb-2 text-[8px] md:text-[10px] font-bold tracking-[0.3em] uppercase text-neutral-500">{typeLabel}</p>
          <h1 class="font-serif text-2xl md:text-5xl leading-none text-white tracking-tighter mb-2 md:mb-4">
            {pageLabel}
          </h1>
          
          {(profile?.tags ?? category?.tags ?? []).length > 0 && (
            <div class="flex flex-wrap gap-2">
              {(profile?.tags ?? category?.tags ?? []).map((tag) => (
                <span class="text-[8px] md:text-[10px] uppercase tracking-[0.2em] border border-white/20 px-2 py-1 text-neutral-400">{tag}</span>
              ))}
            </div>
          )}
        </div>

        <div class="prose prose-invert prose-sm md:prose-base max-w-none text-neutral-400 font-light leading-relaxed">
          <p class="whitespace-pre-line">
            {profile?.bio || category?.description || "Content coming soon."}
          </p>
        </div>

        {embeddedVideos.length > 0 && (
          <div class="mt-6 md:mt-8">
            <div class="mb-3 flex items-center justify-between">
              <p class="text-[8px] md:text-[10px] font-bold tracking-[0.3em] uppercase text-neutral-500">Videos</p>
              <p class="text-[8px] md:text-[10px] uppercase tracking-[0.2em] text-neutral-600">{embeddedVideos.length} items</p>
            </div>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 md:gap-4">
              {embeddedVideos.map((video) => (
                <article class="overflow-hidden border border-white/10 bg-neutral-950">
                  <div class="aspect-video bg-neutral-900">
                    <iframe
                      src={video.embed}
                      title={`${pageLabel} video`}
                      loading="lazy"
                      allow="autoplay; fullscreen; picture-in-picture"
                      allowfullscreen
                      class="h-full w-full"
                    ></iframe>
                  </div>
                  <div class="px-3 py-2">
                    <a href={video.source} target="_blank" rel="noopener noreferrer" class="text-[9px] uppercase tracking-[0.2em] text-neutral-400 transition-colors hover:text-white">
                      Open on Vimeo ↗
                    </a>
                  </div>
                </article>
              ))}
            </div>
          </div>
        )}

        {categoryMedia.length > 0 && (
          <div class="mt-6 md:mt-8">
            <div class="mb-3 flex items-center justify-between">
              <p class="text-[8px] md:text-[10px] font-bold tracking-[0.3em] uppercase text-neutral-500">Media</p>
              <p class="text-[8px] md:text-[10px] uppercase tracking-[0.2em] text-neutral-600">{categoryMedia.length} items</p>
            </div>
            <div class="grid grid-cols-2 md:grid-cols-3 xl:grid-cols-4 gap-2 md:gap-3">
              {categoryMedia.map((item) => (
                <a href={item} target="_blank" rel="noopener noreferrer" class="group block">
                  <div class="relative aspect-[4/5] overflow-hidden bg-neutral-900">
                    <img src={item} alt={pageLabel} class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy" />
                    <div class="absolute inset-0 bg-black/20 group-hover:bg-black/5 transition-colors"></div>
                  </div>
                </a>
              ))}
            </div>
          </div>
        )}
      </div>

    </div>
  ) : (
    <div class="min-h-[40vh] flex flex-col justify-center items-center text-center">
       <h1 class="font-serif text-3xl md:text-5xl text-white mb-4">{pageLabel}</h1>
       <p class="text-neutral-500 text-[10px] tracking-widest uppercase">Page under construction</p>
    </div>
  )}
</Layout>
