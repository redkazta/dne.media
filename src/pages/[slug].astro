---
import Layout from "../layouts/Layout.astro";
import { categoryMediaBySlug, categoryVideoBySlug, managementProfiles, pages, portfolioCategories } from "../data/siteContent";

export function getStaticPaths() {
  const slugs = new Set([
    ...portfolioCategories.map((item) => item.slug),
    ...managementProfiles.map((item) => item.slug)
  ]);

  return Array.from(slugs).map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params;

const category = portfolioCategories.find((item) => item.slug === slug);
const profile = managementProfiles.find((item) => item.slug === slug);
const page = pages.find((item) => item.slug === slug);

const pageLabel = category?.label ?? profile?.label ?? slug;
const pageTitle = page?.title ?? `${pageLabel} | DNE Media`;
const typeLabel = category ? "Portfolio" : "Artist";
const backLink = category ? "/" : "/artists";
const backText = category ? "Home" : "All Artists";
const categoryMedia = category ? categoryMediaBySlug[category.slug] ?? [] : [];
const categoryVideos = category ? categoryVideoBySlug[category.slug] ?? [] : [];
const embeddedVideos = categoryVideos
  .map((url) => {
    const match = url.match(/vimeo\.com\/(\d+)/);
    if (!match) return null;
    return {
      source: url,
      embed: `https://player.vimeo.com/video/${match[1]}`,
      thumbnail: `https://vumbnail.com/${match[1]}.jpg`
    };
  })
  .filter((item): item is { source: string; embed: string; thumbnail: string } => item !== null);
---

<Layout title={pageTitle}>
  <div class="mb-4 md:mb-8">
    <a href={backLink} class="group inline-flex items-center text-[8px] md:text-[10px] uppercase tracking-[0.2em] text-neutral-500 transition-colors hover:text-white">
      <span class="mr-2 transition-transform group-hover:-translate-x-1">←</span> {backText}
    </a>
  </div>

  {profile || category ? (
    <div class="grid gap-6 md:gap-8 lg:grid-cols-12 lg:gap-16">
      
      <!-- Image Column (Sticky on Desktop) -->
      <div class="lg:col-span-4">
        <div class="sticky top-20">
          <div class="relative aspect-[4/5] md:aspect-[3/4] w-full overflow-hidden bg-neutral-900 mb-4 md:mb-6">
            {(profile?.image || category?.image) ? (
              <img 
                src={profile?.image || category?.image} 
                alt={pageLabel} 
                class="h-full w-full object-cover grayscale"
                loading="lazy" 
              />
            ) : (
              <div class="absolute inset-0 flex items-center justify-center text-neutral-700">
                <span class="text-[10px] tracking-widest uppercase">No Image</span>
              </div>
            )}
          </div>
          
          {profile?.socials && (
            <div class="flex flex-col gap-2 md:gap-3 border-t border-white/10 pt-3 md:pt-4">
              <h3 class="text-[8px] md:text-[10px] font-bold tracking-[0.3em] uppercase text-neutral-600">Connect</h3>
              <div class="flex flex-wrap gap-3 md:gap-4">
                {profile.socials.map(social => (
                  <a href={social.url} target="_blank" rel="noopener noreferrer" class="text-[8px] md:text-[10px] uppercase tracking-widest text-neutral-400 transition-colors hover:text-white flex items-center gap-1">
                    {social.label} <span class="opacity-50">↗</span>
                  </a>
                ))}
              </div>
            </div>
          )}
        </div>
      </div>
      
      <!-- Content Column -->
      <div class="lg:col-span-8 flex flex-col justify-start pt-0 md:pt-2">
        <div class="mb-4 md:mb-8">
          <p class="mb-1 md:mb-2 text-[8px] md:text-[10px] font-bold tracking-[0.3em] uppercase text-neutral-500">{typeLabel}</p>
          <h1 class="font-serif text-2xl md:text-5xl leading-none text-white tracking-tighter mb-2 md:mb-4">
            {pageLabel}
          </h1>
          
          {(profile?.tags ?? category?.tags ?? []).length > 0 && (
            <div class="flex flex-wrap gap-2">
              {(profile?.tags ?? category?.tags ?? []).map((tag) => (
                <span class="text-[8px] md:text-[10px] uppercase tracking-[0.2em] border border-white/20 px-2 py-1 text-neutral-400">{tag}</span>
              ))}
            </div>
          )}
        </div>

        <div class="prose prose-invert prose-sm md:prose-base max-w-none text-neutral-400 font-light leading-relaxed">
          <p class="whitespace-pre-line">
            {profile?.bio || category?.description || "Content coming soon."}
          </p>
        </div>

        {embeddedVideos.length > 0 && (
          <div class="mt-6 md:mt-8">
            <div class="mb-3 flex items-center justify-between">
              <p class="text-[8px] md:text-[10px] font-bold tracking-[0.3em] uppercase text-neutral-500">Videos</p>
              <p class="text-[8px] md:text-[10px] uppercase tracking-[0.2em] text-neutral-600">{embeddedVideos.length} items</p>
            </div>
            <div class="grid grid-cols-2 gap-2 md:grid-cols-3 md:gap-3">
              {embeddedVideos.map((video, index) => (
                <button
                  class="group relative overflow-hidden border border-white/10 bg-neutral-950 text-left transition-colors hover:border-white/40"
                  data-video-open
                  data-video-src={video.embed}
                  data-video-title={`${pageLabel} video ${index + 1}`}
                >
                  <div class="relative aspect-[4/5] bg-neutral-900">
                    <img src={video.thumbnail} alt={`${pageLabel} video ${index + 1}`} loading="lazy" class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105" />
                    <div class="absolute inset-0 bg-black/35 transition-colors group-hover:bg-black/20"></div>
                    <div class="absolute left-1/2 top-1/2 flex h-10 w-10 -translate-x-1/2 -translate-y-1/2 items-center justify-center rounded-full border border-white/60 bg-black/50 text-white">
                      ▶
                    </div>
                  </div>
                </button>
              ))}
            </div>
          </div>
        )}

        {categoryMedia.length > 0 && (
          <div class="mt-6 md:mt-8">
            <div class="mb-3 flex items-center justify-between">
              <p class="text-[8px] md:text-[10px] font-bold tracking-[0.3em] uppercase text-neutral-500">Media</p>
              <p class="text-[8px] md:text-[10px] uppercase tracking-[0.2em] text-neutral-600">{categoryMedia.length} items</p>
            </div>
            <div class="grid grid-cols-2 md:grid-cols-3 xl:grid-cols-4 gap-2 md:gap-3">
              {categoryMedia.map((item) => (
                <a href={item} target="_blank" rel="noopener noreferrer" class="group block">
                  <div class="relative aspect-[4/5] overflow-hidden bg-neutral-900">
                    <img src={item} alt={pageLabel} class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy" />
                    <div class="absolute inset-0 bg-black/20 group-hover:bg-black/5 transition-colors"></div>
                  </div>
                </a>
              ))}
            </div>
          </div>
        )}
      </div>

    </div>
  ) : (
    <div class="min-h-[40vh] flex flex-col justify-center items-center text-center">
       <h1 class="font-serif text-3xl md:text-5xl text-white mb-4">{pageLabel}</h1>
       <p class="text-neutral-500 text-[10px] tracking-widest uppercase">Page under construction</p>
    </div>
  )}

  <div id="video-modal" class="pointer-events-none fixed inset-0 z-[70] opacity-0 transition-opacity duration-200">
    <button id="video-modal-backdrop" aria-label="Close video" class="absolute inset-0 bg-black/80"></button>
    <div class="relative z-10 mx-auto flex h-full w-full max-w-5xl items-center px-4 md:px-8">
      <div class="w-full overflow-hidden border border-white/20 bg-black">
        <div class="flex items-center justify-between border-b border-white/10 px-3 py-2">
          <p id="video-modal-title" class="text-[9px] uppercase tracking-[0.2em] text-neutral-400">Video</p>
          <button id="video-modal-close" aria-label="Close video" class="text-lg leading-none text-white/70 transition-colors hover:text-white">×</button>
        </div>
        <div class="aspect-video w-full bg-black">
          <iframe
            id="video-modal-frame"
            src=""
            title="Video"
            loading="lazy"
            allow="autoplay; fullscreen; picture-in-picture"
            allowfullscreen
            class="h-full w-full"
          ></iframe>
        </div>
      </div>
    </div>
  </div>

  <script>
    function setupVideoModal() {
      const modal = document.getElementById("video-modal") as HTMLDivElement | null;
      const frame = document.getElementById("video-modal-frame") as HTMLIFrameElement | null;
      const title = document.getElementById("video-modal-title") as HTMLParagraphElement | null;
      const close = document.getElementById("video-modal-close") as HTMLButtonElement | null;
      const backdrop = document.getElementById("video-modal-backdrop") as HTMLButtonElement | null;
      const triggers = Array.from(document.querySelectorAll("[data-video-open]")) as HTMLButtonElement[];

      if (!modal || !frame || !title || !close || !backdrop || triggers.length === 0) return;
      const safeModal = modal;
      const safeFrame = frame;
      const safeTitle = title;
      const safeClose = close;
      const safeBackdrop = backdrop;

      function openModal(src: string, text: string) {
        safeFrame.src = src;
        safeTitle.textContent = text;
        safeModal.classList.remove("opacity-0", "pointer-events-none");
        document.body.style.overflow = "hidden";
      }

      function closeModal() {
        safeModal.classList.add("opacity-0", "pointer-events-none");
        safeFrame.src = "";
        document.body.style.overflow = "";
      }

      triggers.forEach((trigger) => {
        if (trigger.getAttribute("data-video-bound") === "true") return;
        trigger.setAttribute("data-video-bound", "true");
        trigger.addEventListener("click", () => {
          const src = trigger.getAttribute("data-video-src");
          const text = trigger.getAttribute("data-video-title") ?? "Video";
          if (src) openModal(src, text);
        });
      });

      if (safeClose.getAttribute("data-video-bound") !== "true") {
        safeClose.setAttribute("data-video-bound", "true");
        safeClose.addEventListener("click", closeModal);
      }

      if (safeBackdrop.getAttribute("data-video-bound") !== "true") {
        safeBackdrop.setAttribute("data-video-bound", "true");
        safeBackdrop.addEventListener("click", closeModal);
      }

      if (document.body.getAttribute("data-video-escape-bound") !== "true") {
        document.body.setAttribute("data-video-escape-bound", "true");
        document.addEventListener("keydown", (event) => {
          if (event.key === "Escape") closeModal();
        });
      }
    }

    setupVideoModal();
    document.addEventListener("astro:page-load", setupVideoModal);
  </script>
</Layout>
