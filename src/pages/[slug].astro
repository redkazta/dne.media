---
import Layout from "../layouts/Layout.astro";
import { managementProfiles, pages, portfolioCategories } from "../data/siteContent";

export function getStaticPaths() {
  const slugs = new Set([
    ...portfolioCategories.map((item) => item.slug),
    ...managementProfiles.map((item) => item.slug)
  ]);

  return Array.from(slugs).map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params;

const category = portfolioCategories.find((item) => item.slug === slug);
const profile = managementProfiles.find((item) => item.slug === slug);
const page = pages.find((item) => item.slug === slug);

const pageLabel = category?.label ?? profile?.label ?? slug;
const pageTitle = page?.title ?? `${pageLabel} | DNE Media`;
const typeLabel = category ? "Portfolio" : "Artist";
---

<Layout title={pageTitle}>
  <div class="mb-8">
    <a href="/artists" class="group inline-flex items-center text-[9px] uppercase tracking-[0.2em] text-white/30 transition-colors hover:text-white">
      <span class="mr-2 transition-transform group-hover:-translate-x-1">←</span> Back
    </a>
  </div>

  {profile ? (
    <div class="grid gap-8 md:grid-cols-12 md:gap-12">
      <!-- Image Column -->
      <div class="md:col-span-5 lg:col-span-4">
        <div class="relative aspect-[3/4] w-full overflow-hidden bg-neutral-900/50">
          {profile.image ? (
            <img 
              src={profile.image} 
              alt={pageLabel} 
              class="h-full w-full object-cover transition-all duration-1000 grayscale hover:grayscale-0"
              loading="lazy" 
            />
          ) : (
            <div class="absolute inset-0 flex items-center justify-center text-white/20">
              <span class="text-[9px] tracking-widest uppercase">No Image</span>
            </div>
          )}
        </div>
        
        {profile.socials && (
          <div class="mt-6 flex flex-col gap-1">
            <h3 class="text-[8px] font-bold tracking-[0.3em] uppercase text-white/20 mb-2">Connect</h3>
            {profile.socials.map(social => (
              <a href={social.url} target="_blank" rel="noopener noreferrer" class="group flex items-center justify-between border-b border-white/5 py-1.5 text-[9px] uppercase tracking-widest text-white/50 transition-colors hover:text-white hover:border-white/20">
                <span>{social.label}</span>
                <span class="opacity-0 -translate-x-2 transition-all group-hover:opacity-100 group-hover:translate-x-0">↗</span>
              </a>
            ))}
          </div>
        )}
      </div>
      
      <!-- Content Column -->
      <div class="md:col-span-7 lg:col-span-8 flex flex-col justify-center">
        <div>
          <p class="mb-2 text-[9px] font-bold tracking-[0.3em] uppercase text-white/30">{typeLabel}</p>
          <h1 class="font-serif text-3xl leading-none text-white md:text-5xl tracking-tight mix-blend-difference mb-4">
            {pageLabel}
          </h1>
          {profile.tags && (
            <div class="mb-8 flex flex-wrap gap-2">
              {profile.tags.map(tag => (
                <span class="text-[9px] uppercase tracking-[0.2em] border border-white/10 px-2 py-0.5 rounded-full text-white/40">{tag}</span>
              ))}
            </div>
          )}
        </div>

        <div class="prose prose-invert prose-sm max-w-none">
          <p class="text-white/60 text-xs md:text-sm leading-loose font-light whitespace-pre-line text-justify tracking-wide">
            {profile.bio || "Biography coming soon."}
          </p>
        </div>
      </div>
    </div>
  ) : (
    <div class="min-h-[40vh] flex flex-col justify-center items-center text-center">
       <h1 class="font-serif text-3xl md:text-5xl text-white mb-4">{pageLabel}</h1>
       <p class="text-white/40 text-xs tracking-widest uppercase">Content coming soon</p>
    </div>
  )}
</Layout>
